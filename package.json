{
  "name": "transmi-cli",
  "version": "0.1.0",
  "description": "Planea viajes en transporte público por Bogotá desde la terminal o mediante MCP",
  "type": "module",
  "bin": {
    "transmi": "./bin/transmi.ts"
  },
  "scripts": {
    "dev": "bun run bin/transmi.ts",
    "build": "bun build bin/transmi.ts --compile --outfile transmi",
    "mcp": "bun run src/mcp/server.ts",
    "setup-mcp": "bun run bin/setup-mcp.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "format": "biome format --write .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist data/*.json"
  },
  "keywords": ["transmilenio", "cli", "bogota", "transport", "transit", "colombia"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "chalk": "^5.6.2",
    "commander": "^12.0.0",
    "figlet": "^1.11.3",
    "gradient-string": "^3.0.0",
    "picocolors": "^1.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "@types/figlet": "^1.7.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}

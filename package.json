{
  "name": "transmilenio-cli",
  "version": "1.0.0",
  "description": "CLI tool for Transmilenio system in Bogotá, Colombia",
  "type": "module",
  "bin": {
    "transmi": "./bin/transmi.ts"
  },
  "scripts": {
    "dev": "bun run bin/transmi.ts",
    "build": "bun build bin/transmi.ts --compile --outfile transmi",
    "mcp": "bun run src/mcp/server.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "format": "biome format --write .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist data/*.json"
  },
  "keywords": [
    "transmilenio",
    "cli",
    "bogota",
    "transport",
    "transit",
    "colombia"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "@clack/prompts": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "picocolors": "^1.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
